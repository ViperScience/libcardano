@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Botan)
# vcpkg's static triplets export only Botan::Botan-static, while a shared/system
# install provides Botan::Botan. The build tree normalises to Botan::Botan, so
# recreate that alias here for consumers of the installed package.
if(NOT TARGET Botan::Botan AND TARGET Botan::Botan-static)
    add_library(Botan::Botan ALIAS Botan::Botan-static)
endif()
find_dependency(Threads)
find_dependency(@CARDANO_SODIUM_DEPENDENCY@)
find_dependency(cppbor)
find_dependency(nlohmann_json)
# Note: Some of the find_dependency calls above may need the custom Find files
# included in the libCardano repository.

include("${CMAKE_CURRENT_LIST_DIR}/cardanoTargets.cmake")

check_required_components(cardano)